# AgentsHive companion webapp (Vite) — copy to .env.local (gitignored).
# Same Supabase project as the desktop app (publishable/anon key — safe in a browser).
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
# The AgentsHive server the webapp talks to (local dev or the deployed URL).
VITE_AGENTSHIVE_URL=http://localhost:8000
