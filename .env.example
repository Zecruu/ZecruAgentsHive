AGENTSHIVE_API_KEY=replace-with-a-long-random-string
DATABASE_URL=sqlite:///./agentshive.db
PORT=8000
POLL_INTERVAL_SECONDS=2
TOOL_BLOCK_TIMEOUT_SECONDS=50

# --- v2.x Supabase auth + multi-tenancy ---
# When SUPABASE_URL is set, the server ALSO accepts Supabase access tokens
# (verified via that project's JWKS endpoint) and binds each to tenant_id = the
# token's `sub`. The legacy AGENTSHIVE_API_KEY keeps working and maps to the
# reserved "legacy" tenant. Leave SUPABASE_URL unset for single-tenant/legacy mode.
SUPABASE_URL=
# For a Postgres backend (multi-tenant), set DATABASE_URL to the Supabase
# connection string, e.g.:
#   DATABASE_URL=postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
# If the direct db.<ref> host is IPv6-only, use the pooler host instead:
#   postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Stripe (P2 — deferred) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
